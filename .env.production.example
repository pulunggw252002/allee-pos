# ─── ALLEE POS — production env template ────────────────────────────────────
# Salin file ini jadi `.env.production` (atau set di platform hosting-mu)
# dan isi dengan nilai asli. JANGAN commit `.env.production`.

# Turso DB — dapatkan dari `turso db show <db-name>` + `turso db tokens create <db-name>`
DATABASE_URL=libsql://<your-db>-<your-org>.turso.io
DATABASE_AUTH_TOKEN=<paste-token-from-turso-cli>

# Better Auth — WAJIB di-set ke random 32+ chars untuk prod
# Generate: `openssl rand -base64 32` atau `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
BETTER_AUTH_SECRET=<random-32-char-secret>

# URL publik aplikasi (tanpa trailing slash). Di-pakai Better Auth untuk cookie + redirect.
BETTER_AUTH_URL=https://pos.allee.example.com

# ─── Backoffice integration (ALLEE Backoffice ↔ POS) ────────────────────────
# Lihat docs/BACKOFFICE_INTEGRATION.md untuk panduan integrasi penuh.

# Master toggle. Saat OFF (default), POS jalan stand-alone (DB lokal sebagai
# source of truth). Saat ON, POS membaca catalog/users dari backoffice dan
# men-push transaksi & void ke backoffice.
BACKOFFICE_MODE=false

# Base URL backoffice API (tanpa trailing slash). Termasuk path `/api`.
# Contoh prod: https://allee-backoffice.vercel.app
# Contoh local: http://localhost:3000
BACKOFFICE_API_URL=https://allee-backoffice.vercel.app

# Service account untuk POS → backoffice (interim sampai PIN endpoint ship).
# Email & password staff yang punya role "kasir" atau "kepala_toko" — owner
# membuatnya di Backoffice → Users. Dipakai POS device untuk sign-in ke
# backoffice sekali saat boot, lalu cookie session dipakai untuk semua call.
BACKOFFICE_SERVICE_EMAIL=<email@allee.local>
BACKOFFICE_SERVICE_PASSWORD=<password-from-backoffice>

# Outlet override. Kalau di-set, POS lock ke outlet ini (cocok untuk MVP
# 1-cabang). Kalau kosong, POS auto-detect dari `GET /api/session.outlet_id`
# setelah sign-in.
NEXT_PUBLIC_OUTLET_ID=
